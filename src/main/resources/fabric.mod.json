{
	"schemaVersion": 1,
	"id": "toads_simple_origins-fish_bowl",
	"version": "${version}",
	"name": "toads_simple_origins-fish_bowl",
	"description": "A mod that adds the Toad's Simple Origins fishbowl armor.",
	"authors": [
		"SpottedToad"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/toads_simple_origins-fish_bowl",
		"sources": "https://github.com/SpottedToad/toads_simple_origins-fish_bowl",
		"issues": "https://github.com/SpottedToad/toads_simple_origins-fish_bowl/issues"
	},
	"license": "MIT",
	"icon": "assets/toads_simple_origins/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.spottedtoad.toads_simple_origins.TSOMod"
		],
		"fabric-datagen": [
			"net.spottedtoad.toads_simple_origins.TSOModDataGenerator"
		],
		"client": [
			"net.spottedtoad.toads_simple_origins.TSOModClient"
		]
	},
	"mixins": [
		"toads_simple_origins.mixins.json"
	],
