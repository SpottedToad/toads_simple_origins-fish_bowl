					"id": "origins",
					"relationship": "required",
					"version": "1.21.1"
				}
			]
		}
	},
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.1",
		"azurelib": ">=3.1.10",
		"java": ">=21",
		"origins": ">=1.13.0-pre.2"
	},
	"after": [
		"origins",
		"apoli"
	]
}